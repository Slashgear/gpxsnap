{
  "name": "gpxsnap",
  "version": "1.0.1",
  "description": "Dependency-free GPX route-preview PNG renderer for Bun — no native bindings anywhere in the chain",
  "keywords": [
    "bun",
    "gpx",
    "openstreetmap",
    "png",
    "route",
    "static-map"
  ],
  "homepage": "https://github.com/Slashgear/gpxsnap/tree/main/packages/gpxsnap#readme",
  "bugs": {
    "url": "https://github.com/Slashgear/gpxsnap/issues"
  },
  "license": "MIT",
  "author": "Antoine Caron",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Slashgear/gpxsnap.git",
    "directory": "packages/gpxsnap"
  },
  "files": [
    "src"
  ],
  "type": "module",
  "module": "src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./gpx": {
      "types": "./src/gpx.ts",
      "default": "./src/gpx.ts"
    }
  },
  "scripts": {
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint .",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:e2e:bun": "bun test/e2e/render.e2e.ts",
    "test:e2e:node": "node test/e2e/render.e2e.ts",
    "test:e2e:deno": "deno run --allow-read --allow-net test/e2e/render.e2e.ts"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "engines": {
    "bun": ">=1.3.0",
    "deno": ">=1.0.0",
    "node": ">=22.18.0"
  }
}
