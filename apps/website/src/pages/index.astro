---
const sampleSrc = `${import.meta.env.BASE_URL}sample.png`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Turn a GPX file into a map image, right in your browser. Powered by gpxsnap, a dependency-free renderer for Bun, Node, and Deno."
    />
    <title>gpxsnap — turn a GPX file into a map image</title>
  </head>
  <body>
    <nav>
      <span class="brand">gpxsnap</span>
      <div class="nav-links">
        <a href="https://github.com/Slashgear/gpxsnap">GitHub</a>
        <a href="https://www.npmjs.com/package/gpxsnap">npm</a>
      </div>
    </nav>

    <header class="hero">
      <h1>Turn a GPX file into a map image</h1>
      <p class="tagline">
        Upload a route below and get a PNG back — rendered entirely in your
        browser. Nothing is uploaded to a server.
      </p>
    </header>

    <main>
      <section id="demo" class="card">
        <form id="demo-form">
          <label>
            GPX file
            <input type="file" id="gpx-file" accept=".gpx" required />
          </label>
          <div class="field-row">
            <label>
              Width
              <input type="number" id="width" value="1000" min="200" max="2000" />
            </label>
            <label>
              Height
              <input type="number" id="height" value="700" min="200" max="2000" />
            </label>
            <label>
              Line color
              <input type="color" id="line-color" value="#e74c3c" />
            </label>
          </div>
          <label>
            Title (optional)
            <input type="text" id="title" placeholder="Auto-detected from the GPX file's name" />
          </label>
          <div class="field-row checkbox-row">
            <label class="checkbox-label">
              <input type="checkbox" id="show-title" checked />
              Show title
            </label>
            <label class="checkbox-label">
              <input type="checkbox" id="show-stats" checked />
              Stats (distance, elevation)
            </label>
            <label class="checkbox-label">
              <input type="checkbox" id="show-elevation-profile" checked />
              Elevation profile
            </label>
          </div>
          <button type="submit" class="button">Render</button>
        </form>
        <p id="demo-status" role="status"></p>
        <div id="demo-result"></div>
        <p class="caption">
          Map tiles are fetched directly from <code>tile.openstreetmap.org</code>
          — no proxy, no backend.
        </p>
      </section>

      <section class="about">
        <p class="eyebrow">Powered by</p>
        <h2>gpxsnap</h2>
        <p class="tagline">
          A dependency-free GPX route-preview renderer — no <code>sharp</code>,
          no <code>libvips</code>, no native bindings anywhere in the chain.
          The same library behind the demo above runs in Bun, Node (≥22.18),
          and Deno too.
        </p>

        <figure>
          <img
            src={sampleSrc}
            alt="A real ~1200-point GPS track rendered near Lyon, France, hugging real roads"
            width="900"
            height="675"
            loading="lazy"
          />
          <figcaption class="caption">
            A real recorded ride, rendered by gpxsnap — dense GPS data
            already hugs the road network with a plain polyline stroke, no
            map-matching required.
          </figcaption>
        </figure>

        <h3>Install</h3>
        <pre><code>bun add gpxsnap</code></pre>
        <pre><code>{`import { renderRoute } from "gpxsnap";

const png = await renderRoute({
  coordinates: [[2.3522, 48.8566], [2.295, 48.8738], [2.2986, 48.8867]],
  width: 1200,
  height: 600,
});`}</code></pre>

        <div class="cta">
          <a class="button secondary" href="https://github.com/Slashgear/gpxsnap">GitHub</a>
          <a class="button secondary" href="https://www.npmjs.com/package/gpxsnap">npm</a>
        </div>
      </section>
    </main>

    <script src="../demo.client.ts"></script>

    <footer>
      <p>
        MIT licensed. <a href="https://github.com/Slashgear/gpxsnap">Source on GitHub</a>.
      </p>
    </footer>
  </body>
</html>

<style>
  :root {
    color-scheme: light dark;
    --ink: light-dark(#20281f, #e7ecdd);
    --muted: light-dark(#5b6456, #9caa8f);
    --bg: light-dark(#eef1e9, #141c13);
    --surface: light-dark(#e2e7da, #1e2a1b);
    --border: light-dark(#c7ceb9, #2e3d29);
    --accent: light-dark(#b8792b, #d99b4c);
  }

  * {
    box-sizing: border-box;
  }

  :global(html, body) {
    margin: 0;
    padding: 0;
    background: var(--bg);
    color: var(--ink);
    font-family:
      -apple-system,
      "Segoe UI",
      Roboto,
      sans-serif;
    line-height: 1.6;
    /* Never let anything (a too-wide image, a long unbroken token) push the
       viewport wider than the screen — belt-and-suspenders alongside the
       per-element max-width rules below. */
    overflow-x: hidden;
  }

  nav {
    max-width: 900px;
    margin: 0 auto;
    padding: 20px 24px 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .brand {
    font-weight: 700;
    font-family: ui-monospace, "SF Mono", monospace;
  }

  .nav-links {
    display: flex;
    gap: 18px;
  }

  .nav-links a {
    color: var(--muted);
    text-decoration: none;
  }

  .nav-links a:hover {
    color: var(--ink);
  }

  .hero {
    max-width: 720px;
    margin: 0 auto;
    padding: 32px 24px 24px;
    text-align: center;
  }

  h1 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    margin: 0 0 16px;
  }

  .eyebrow {
    font-family: ui-monospace, "SF Mono", monospace;
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 8px;
  }

  .tagline {
    color: var(--muted);
    font-size: 1.05rem;
  }

  code {
    font-family: ui-monospace, "SF Mono", monospace;
  }

  .cta {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 24px;
  }

  .button {
    display: inline-block;
    padding: 10px 18px;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 600;
    background: var(--accent);
    color: #fff;
  }

  .button.secondary {
    background: var(--surface);
    color: var(--ink);
    border: 1px solid var(--border);
  }

  main {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 24px 64px;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 24px;
  }

  .about {
    padding-top: 8px;
  }

  figure {
    margin: 20px 0;
  }

  /* :global() because the demo's result <img> is inserted by client-side JS
     and never gets Astro's scoped-style attribute — without :global() this
     rule silently wouldn't apply to it, which is exactly what caused the
     unconstrained/overflowing image before this fix. */
  :global(main img) {
    display: block;
    max-width: 100%;
    height: auto;
    border-radius: 6px;
    border: 1px solid var(--border);
  }

  .caption {
    color: var(--muted);
    font-size: 0.9rem;
    margin: 8px 0 0;
  }

  pre {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 16px 18px;
    max-width: 100%;
    overflow-x: auto;
  }

  #demo-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  #demo-form label {
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: 0.9rem;
    color: var(--muted);
  }

  #demo-form input {
    font: inherit;
    padding: 8px 10px;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--ink);
  }

  .field-row {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .field-row label {
    flex: 1;
    min-width: 120px;
  }

  .checkbox-row {
    gap: 20px;
  }

  .checkbox-label {
    flex-direction: row !important;
    align-items: center;
    gap: 8px !important;
    flex: initial;
  }

  .checkbox-label input {
    width: auto;
    padding: 0;
  }

  #demo-form button {
    align-self: flex-start;
    border: none;
    cursor: pointer;
    font: inherit;
  }

  #demo-form button:disabled {
    opacity: 0.6;
    cursor: wait;
  }

  #demo-status {
    color: var(--muted);
    min-height: 1.5em;
    margin-bottom: 0;
  }

  #demo-result {
    margin-top: 8px;
  }

  #demo-result :global(img) {
    margin-bottom: 8px;
  }

  footer {
    max-width: 900px;
    margin: 0 auto;
    padding: 24px;
    text-align: center;
    color: var(--muted);
    font-size: 0.9rem;
  }
</style>
